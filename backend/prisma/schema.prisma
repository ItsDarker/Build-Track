generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  name                 String?
  firstName            String?             @map("first_name")
  lastName             String?             @map("last_name")
  displayName          String?             @map("display_name")
  avatarUrl            String?             @map("avatar_url")
  userType             String?             @map("user_type")
  userStatus           String?             @default("Active") @map("user_status")
  team                 String?
  email                String              @unique
  passwordHash         String?             @map("password_hash")
  emailVerified        DateTime?           @map("email_verified_at")
  phone                String?
  company              String?
  jobTitle             String?             @map("job_title")
  bio                  String?
  isBlocked            Boolean             @default(false) @map("is_blocked")
  blockedAt            DateTime?           @map("blocked_at")
  blockedReason        String?             @map("blocked_reason")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  roleId               String?             @map("role_id")
  loginAttempts        LoginAttempt[]
  oauthAccounts        OAuthAccount[]
  managedProjects      Project[]           @relation("ProjectManager")
  assignedProjects     Project[]           @relation("ProjectAssignee")
  refreshTokens        RefreshToken[]
  deviceTokens         DeviceToken[]
  assignedTasks        Task[]              @relation("TaskAssignee")
  role                 Role?               @relation(fields: [roleId], references: [id])
  verificationTokens   VerificationToken[]
  createdModuleRecords ModuleRecord[]      @relation("ModuleRecordCreatedBy")
  updatedModuleRecords ModuleRecord[]      @relation("ModuleRecordUpdatedBy")
  attachments          Attachment[]
  sentInvitations      ProjectInvitation[] @relation("SentInvitations")
  receivedInvitations  ProjectInvitation[] @relation("ReceivedInvitations")
  notifications        Notification[]
  projectMemberships   ProjectMember[]
  teamInvitations      Invitation[]

  @@map("users")
}

model ModuleRecord {
  id         String @id @default(cuid())
  moduleSlug String @map("module_slug")
  data       Json   @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdById String? @map("created_by_id")
  updatedById String? @map("updated_by_id")

  createdBy   User?          @relation("ModuleRecordCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?          @relation("ModuleRecordUpdatedBy", fields: [updatedById], references: [id])
  attachments Attachment[]

  @@index([moduleSlug])
  @@map("module_records")
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  path      String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  // Polymorphic-like relations
  moduleRecordId String? @map("module_record_id")
  projectId      String? @map("project_id")
  taskId         String? @map("task_id")
  uploadedById   String? @map("uploaded_by_id")

  moduleRecord ModuleRecord? @relation(fields: [moduleRecordId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task         Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy   User?         @relation(fields: [uploadedById], references: [id])

  @@map("attachments")
}


model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  displayName String           @map("display_name")
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  action      String
  resource    String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@unique([action, resource])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  provider          String
  providerAccountId String   @map("provider_account_id")
  accessToken       String?  @map("access_token")
  refreshToken      String?  @map("refresh_token")
  expiresAt         Int?     @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model DeviceToken {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  deviceName      String   @map("device_name")
  deviceFingerprint String @unique @map("device_fingerprint")
  userAgent       String   @map("user_agent")
  ipAddress       String   @map("ip_address")
  deviceToken     String   @unique @map("device_token")
  expiresAt       DateTime @map("expires_at")
  lastUsedAt      DateTime @default(now()) @map("last_used_at")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceFingerprint])
  @@map("device_tokens")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  email     String
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([email, createdAt])
  @@index([ip, createdAt])
  @@map("login_attempts")
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  data      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_notifications")
}

model SiteContent {
  id        String   @id @default(cuid())
  page      String   @unique
  sections  String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("site_content")
}

model ContentImage {
  id        String   @id @default(cuid())
  filename  String
  path      String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  @@map("content_images")
}

model Client {
  id                      String    @id @default(cuid())
  name                    String
  email                   String?
  phone                   String?
  altPhone                String?   @map("alt_phone")
  company                 String?
  role                    String?   // Owner | Manager | Purchasing
  projectAddress          String?   @map("project_address")
  billingAddress          String?   @map("billing_address")
  address                 String?   // legacy — kept for backward compat
  preferredApprovalMethod String?   @map("preferred_approval_method")
  notes                   String?
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  projects                Project[]

  @@map("clients")
}

model Project {
  id                 String    @id @default(cuid())
  name               String
  code               String?
  description        String?
  status             String    @default("PLANNING")
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  cancellationReason String?   @map("cancellation_reason")
  completionNote     String?   @map("completion_note")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  clientId           String?   @map("client_id")
  managerId          String?   @map("manager_id")
  assignedToId       String?   @map("assigned_to_id")
  client             Client?   @relation(fields: [clientId], references: [id])
  manager            User?     @relation("ProjectManager", fields: [managerId], references: [id])
  assignedTo         User?     @relation("ProjectAssignee", fields: [assignedToId], references: [id])
  tasks              Task[]
  attachments        Attachment[]
  invitations        ProjectInvitation[]
  members            ProjectMember[]

  @@map("projects")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  projectId   String    @map("project_id")
  assigneeId  String?   @map("assignee_id")
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@map("tasks")
}

// BT0006: Team entity — defines team groups (separate from the user's team field)
model Team {
  id        String   @id @default(cuid())
  name      String
  teamType  String?  @map("team_type")
  status    String   @default("Active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("teams")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      String   @default("SUBCONTRACTOR")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  status    String   @default("PENDING")
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Lookup {
  id         String   @id @default(cuid())
  moduleSlug String?  @map("module_slug")
  category   String
  value      String
  label      String?
  order      Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([moduleSlug, category, value])
  @@map("lookups")
}

model ProjectInvitation {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  inviterId    String    @map("inviter_id")
  inviteeId    String    @map("invitee_id")
  status       String    @default("PENDING")
  message      String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter      User      @relation("SentInvitations", fields: [inviterId], references: [id])
  invitee      User      @relation("ReceivedInvitations", fields: [inviteeId], references: [id])
  notification Notification?

  @@unique([projectId, inviteeId])
  @@index([inviterId])
  @@index([inviteeId])
  @@map("project_invitations")
}

model Notification {
  id           String             @id @default(cuid())
  userId       String             @map("user_id")
  type         String
  title        String
  message      String
  read         Boolean            @default(false)
  data         String?
  invitationId String?            @unique @map("invitation_id")
  createdAt    DateTime           @default(now()) @map("created_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitation   ProjectInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}
