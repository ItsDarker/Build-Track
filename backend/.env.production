# BuildTrack Backend - Production Configuration
# Generated from buildtrac-app service account

PORT=4000
NODE_ENV=production
DATABASE_URL=postgresql://user:password@your-db-host:5432/buildtrack_prod

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-jwt-secret-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Frontend
# ============================================
FRONTEND_URL=https://your-frontend-domain.com

# ============================================
# Email Configuration
# ============================================
MAIL_MODE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@buildtrack.local

# ============================================
# Verification & Security
# ============================================
VERIFICATION_TOKEN_EXPIRES_MINUTES=60
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ============================================
# Cookies
# ============================================
COOKIE_DOMAIN=your-domain.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# ============================================
# Google Drive Integration
# Service Account: buildtrack-file-service@buildtrac-app.iam.gserviceaccount.com
# Project: buildtrac-app (Project ID: buildtrac-app, Project Number: 102021166885)
# ============================================
